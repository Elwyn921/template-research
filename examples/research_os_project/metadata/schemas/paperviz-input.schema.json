{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Constrained PaperVizAgent Input",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "filename",
      "caption",
      "content",
      "visual_intent",
      "additional_info",
      "max_critic_rounds"
    ],
    "properties": {
      "filename": {"type": "string"},
      "caption": {"type": "string"},
      "content": {"type": "string"},
      "visual_intent": {"type": "string"},
      "candidate_id": {"type": "integer"},
      "max_critic_rounds": {"type": "integer", "minimum": 0},
      "additional_info": {
        "type": "object",
        "required": ["rounded_ratio", "source_files"],
        "properties": {
          "rounded_ratio": {"type": "string"},
          "source_files": {"type": "array", "items": {"type": "string"}},
          "contract": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "additionalProperties": true
  }
}
